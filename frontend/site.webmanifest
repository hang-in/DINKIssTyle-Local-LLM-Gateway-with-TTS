{
    "name": "DKST LLM Chat Server",
    "short_name": "DKST Server",
    "description": "Local LLM Gateway with TTS Web Client",
    "start_url": "/index.html",
    "display": "standalone",
    "background_color": "#0f172a",
    "theme_color": "#0f172a",
    "icons": [
        {
            "src": "public/favicon-32.png",
            "sizes": "32x32",
            "type": "image/png"
        },
        {
            "src": "public/apple-touch-icon.png",
            "sizes": "180x180",
            "type": "image/png"
        },
        {
            "src": "public/icon-192.png",
            "sizes": "192x192",
            "type": "image/png"
        },
        {
            "src": "public/icon-512.png",
            "sizes": "512x512",
            "type": "image/png"
        }
    ]
}
